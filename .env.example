# Secret salt used to hash visitor IPs so raw IPs are never stored. CHANGE THIS.
IP_SALT=

# Allowed origins for the API. Use "*" for local dev; set your domain in prod,
# e.g. CORS_ORIGINS=https://chabaka.example.com
CORS_ORIGINS=*

# --- Optional: spike-detection tuning ---
# Time window (minutes) used for "right now" report/measurement counts.
WINDOW_MIN=15
# Absolute report counts that trip degraded / outage when there's no baseline yet.
DEGRADED_ABS=4
OUTAGE_ABS=10
